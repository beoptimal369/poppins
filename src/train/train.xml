  <responses>
    <response id="1">A computer is a computing / information processing device.</response>
    <response id="2">JavaScript (JS) is a lightweight interpreted (or just-in-time compiled) programming language.</response>
    <response id="3">JavaScript contains a standard library of objects, such as Array, Map, and Math, and a core set of language elements such as operators, control structures, and statements. Example Code:</response>
  </responses>


  <sources>
    <source id="1" url="https://en-word.net/lemma/computer" />
    <source id="2" url="https://developer.mozilla.org/en-US/docs/Web/JavaScript" />
    <source id="3" url="https://developer.mozilla.org/en-US/docs/Web/JavaScript/Guide/Introduction" />
  </sources>


  <code-snippets>
    <code id="1" lang="ts">function example() {
  console.log('hi world')
}</code>
  </code-snippets>

  <samples>
    <sample-ids prompt="1" response="1" source="1" />
    <sample>
      <prompt id="2" />
      <response id="2" />
      <source id="2" />
      <line-break count="1" />
      <response id="3" />
      <source id="3" />
      <code id="1" />
