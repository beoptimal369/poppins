<?xml version="1.0" encoding="UTF-8"?>
<!-- train.xml -->
<train xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="https://xsd.beoptimal369.workers.dev/?version=0.1.0">
  <prompts>
    <prompt id="1">What is a computer?</prompt>
    <prompt id="2">What is JavaScript?</prompt>
  </prompts>


  <responses>
    <response id="1">A computer is a computing / information processing device.</response>
    <response id="2">JavaScript (JS) is a lightweight interpreted (or just-in-time compiled)
      programming language.</response>
    <response id="3">JavaScript contains a standard library of objects, such as Array, Map, and
      Math, and a core set of language elements such as operators, control structures, and
      statements. Example Code:</response>
  </responses>


  <sources>
    <source id="1" url="https://en-word.net/lemma/computer" />
    <source id="2" url="https://developer.mozilla.org/en-US/docs/Web/JavaScript" />
    <source id="3" url="https://developer.mozilla.org/en-US/docs/Web/JavaScript/Guide/Introduction" />
  </sources>


  <code-snippets>
    <code id="1" lang="ts"> function example() { console.log('hi world') } </code>
  </code-snippets>

  <samples>
    <sample-ids prompt="1" response="1" source="1" />
    <sample>
      <prompt id="2" />
      <response id="2" />
      <source id="2" />
      <line-break count="1" />
      <response id="3" />
      <source id="3" />
      <code id="1" />
    </sample>
  </samples>


  <constants>
    <constant key="aim_train_gb" value="3.0" />
    <constant key="aim_infer_f16_gb" value="0.9" />
    <constant key="learning_rate" value="1e-3" />
    <constant key="warmup_steps" value="100" />
    <constant key="aim_loss" value="0.45" />
    <constant key="val_interval" value="10" />

    <constant key="weight_decay_response" value="0.1" />
    <constant key="weight_decay_source" value="0.01" />
    <constant key="weight_decay_code" value="0.05" />

    <constant key="dropout_rate_response" value="0.05" />
    <constant key="dropout_rate_source" value="0.0" />
    <constant key="dropout_rate_code" value="0.1" />

    <constant key="loss_scale_response" value="1.0" />
    <constant key="loss_scale_source" value="0.2" />
    <constant key="loss_scale_code" value="1.0" />

    <constant key="gradient_scale_response" value="1.0" />
    <constant key="gradient_scale_source" value="2.0" />
    <constant key="gradient_scale_code" value="1.2" />

    <constant key="gradient_clip_response" value="1.0" />
    <constant key="gradient_clip_source" value="0.1" />
    <constant key="gradient_clip_code" value="0.7" />
  </constants>


  <phrases>
    <phrase pattern="What is (?:a |an |the )?(.*?)\?">
      <variant value="Define $1." />
      <variant value="Define: $1." />
    </phrase>
    <phrase pattern="ty">
      <variant value="thanks" />
      <variant value="thank you" />
    </phrase>
  </phrases>
</train>